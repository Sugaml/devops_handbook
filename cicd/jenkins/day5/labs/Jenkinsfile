pipeline {
    agent any

    environment {
        IMAGE_NAME = 'your-dockerhub-user/sample-web'
    }

    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Test') {
            steps {
                sh '''
                    python3 -m venv .venv && . .venv/bin/activate
                    pip install -r requirements.txt
                    pytest -v
                '''
            }
        }
        stage('Build Image') {
            steps {
                script {
                    def shortSha = env.GIT_COMMIT?.take(7) ?: 'local'
                    env.IMAGE_TAG = "${IMAGE_NAME}:${shortSha}"
                    docker.build(env.IMAGE_TAG)
                }
            }
        }
        stage('Push') {
            when { branch 'main' }
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-hub') {
                        def img = docker.image("${env.IMAGE_TAG}")
                        img.push()
                    }
                }
            }
        }
    }

    post {
        always { cleanWs() }
    }
}
