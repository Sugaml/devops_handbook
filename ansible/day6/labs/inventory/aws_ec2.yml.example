# Optional AWS EC2 dynamic inventory — requires amazon.aws collection and AWS credentials.
---
plugin: amazon.aws.aws_ec2
regions:
  - us-east-1
filters:
  tag:Project: devops-handbook
  instance-state-name: running
keyed_groups:
  - key: tags.Role
    prefix: role
hostnames:
  - tag:Name
compose:
  ansible_host: public_ip_address | default(private_ip_address)
